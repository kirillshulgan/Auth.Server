@page
@model Auth.Server.Pages.LoginModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "Вход";
}

<div class="auth-container">
    <div class="auth-card">

        <!-- Логотип -->
        <div class="auth-logo">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="24" fill="#6366f1" />
                <circle cx="24" cy="20" r="7" fill="white" />
                <ellipse cx="24" cy="38" rx="11" ry="7" fill="white" />
            </svg>
        </div>

        <h1 class="auth-title">Войдите в аккаунт</h1>

        @if (!string.IsNullOrEmpty(Model.AppName))
        {
            <p class="auth-subtitle">
                Для доступа к <strong>@Model.AppName</strong>
            </p>
        }
        else
        {
            <p class="auth-subtitle">auth.shulgan-lab.ru</p>
        }

        <!-- Ошибка -->
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="auth-error">
                <span>⚠️</span> @Model.Error
            </div>
        }

        <!-- Tabs -->
        <div class="auth-tabs">
            <button class="tab @(Model.ActiveTab == "password" ? "active" : "")"
                    data-tab="password">
                🔑 Пароль
            </button>
            <button class="tab @(Model.ActiveTab == "otp" ? "active" : "")"
                    data-tab="otp">
                📧 Код на email
            </button>
        </div>

        <!-- ── Вкладка: Логин + Пароль ── -->
        <div class="tab-content @(Model.ActiveTab == "password" ? "active" : "")"
             id="tab-password">
            <form method="post" asp-page-handler="Password">
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                <div class="field">
                    <label for="username">Email или логин</label>
                    <input type="text"
                           id="username"
                           name="username"
                           value="@Model.Username"
                           placeholder="user@example.com"
                           autocomplete="username"
                           required
                           autofocus />
                </div>

                <div class="field">
                    <label for="password">Пароль</label>
                    <div class="field-password">
                        <input type="password"
                               id="password"
                               name="password"
                               placeholder="••••••••"
                               autocomplete="current-password"
                               required />
                        <button type="button" class="toggle-password" tabindex="-1"
                                onclick="togglePassword()">
                            👁
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-primary">Войти</button>
            </form>
        </div>

        <!-- ── Вкладка: Email OTP ── -->
        <div class="tab-content @(Model.ActiveTab == "otp" ? "active" : "")"
             id="tab-otp">

            <!-- Шаг 1: Ввод email -->
            <div id="otp-step-email">
                <div class="field">
                    <label for="otp-email">Email</label>
                    <input type="email"
                           id="otp-email"
                           placeholder="user@example.com"
                           autocomplete="email" />
                </div>
                <button class="btn-primary" id="btn-send-otp" onclick="sendOtp()">
                    Получить код
                </button>
            </div>

            <!-- Шаг 2: Ввод кода -->
            <div id="otp-step-code" style="display:none">
                <p class="otp-hint">
                    Код отправлен на <strong id="otp-email-display"></strong>
                    <button type="button" class="btn-link-inline" onclick="resetOtp()">
                        Изменить
                    </button>
                </p>

                <form method="post" asp-page-handler="Otp">
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                    <input type="hidden" name="email" id="otp-email-hidden" />

                    <div class="field">
                        <label for="otp-code">Код из письма</label>
                        <input type="text"
                               id="otp-code"
                               name="code"
                               placeholder="000000"
                               maxlength="6"
                               class="input-otp"
                               autocomplete="one-time-code"
                               inputmode="numeric"
                               pattern="[0-9]{6}"
                               required
                               autofocus />
                    </div>

                    <button type="submit" class="btn-primary">Подтвердить</button>
                </form>

                <!-- Таймер повторной отправки -->
                <p class="otp-resend" id="otp-resend-wrap">
                    Не получили? <button type="button" class="btn-link-inline"
                                         id="btn-resend" onclick="resendOtp()" disabled>
                        Отправить снова <span id="otp-timer"></span>
                    </button>
                </p>
            </div>
        </div>

        <!-- Разделитель -->
        <div class="auth-divider"><span>или войдите через</span></div>

        <!-- Социальные кнопки -->
        <div class="social-buttons">
            <a href="/connect/social/google?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "/")"
               class="btn-social">
                <!-- Google SVG -->
                <svg width="18" height="18" viewBox="0 0 48 48">
                    <path fill="#FFC107" d="M43.6 20H24v8h11.3C33.6 33.1 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20c11 0 19.7-8 19.7-20 0-1.3-.1-2.7-.1-4z" />
                    <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 16 19 13 24 13c3.1 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4 16.3 4 9.7 8.3 6.3 14.7z" />
                    <path fill="#4CAF50" d="M24 44c5.2 0 9.9-1.9 13.5-5l-6.2-5.2C29.4 35.5 26.8 36 24 36c-5.2 0-9.6-2.9-11.3-7.1l-6.6 4.9C9.6 39.6 16.3 44 24 44z" />
                    <path fill="#1976D2" d="M43.6 20H24v8h11.3c-.9 2.5-2.6 4.6-4.8 6l6.2 5.2C40.3 35.5 44 30.2 44 24c0-1.3-.1-2.7-.4-4z" />
                </svg>
                Google
            </a>

            <button type="button"
                    class="btn-social"
                    data-return-url="/TelegramProfile"
                    onclick="openTelegramPopup(this.dataset.returnUrl)">
                <svg width="18" height="18" viewBox="0 0 48 48">
                    <circle cx="24" cy="24" r="24" fill="#29B6F6" />
                    <path fill="white" d="M35.9 13.2L10 23.1c-1.6.6-1.6 1.5-.3 1.9l6.5 2 15-9.5c.7-.4 1.3-.2.8.3L19.3 29l-.5 6.6c.7 0 1-.3 1.4-.7l3.4-3.3 6.6 4.9c1.2.7 2 .3 2.3-1.1l4.2-19.8c.4-1.7-.6-2.4-1.8-1.4z" />
                </svg>
                Telegram
            </button>
        </div>

        <div class="auth-divider"><span>нет аккаунта?</span></div>

        <a href="/Register?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "/")"
           class="btn-secondary" style="display:block;text-align:center;text-decoration:none">
            Зарегистрироваться
        </a>

    </div>
</div>

<script>
    window.TELEGRAM_CLIENT_ID = @(Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(
            Model.TelegramClientId)));
</script>

@section Scripts {
    <script src="~/js/auth.js"></script>
}
