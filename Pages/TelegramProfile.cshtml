@page
@model Auth.Server.Pages.TelegramProfileModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "Профиль";
}

<div class="auth-container">
    <div class="auth-card">

        <div class="auth-logo">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="24" fill="#29B6F6" />
                <path fill="white" d="M35.9 13.2L10 23.1c-1.6.6-1.6 1.5-.3 1.9l6.5 2 15-9.5c.7-.4 1.3-.2.8.3L19.3 29l-.5 6.6c.7 0 1-.3 1.4-.7l3.4-3.3 6.6 4.9c1.2.7 2 .3 2.3-1.1l4.2-19.8c.4-1.7-.6-2.4-1.8-1.4z" />
            </svg>
        </div>

        <h1 class="auth-title">Вы вошли через Telegram</h1>

        @if (Model.AppUser is not null)
        {
            <div class="profile-info">
                <div class="profile-row">
                    <span class="profile-label">🎱 ID</span>
                    <span class="profile-value">@Model.AppUser.Id</span>
                </div>
                <div class="profile-row">
                    <span class="profile-label">👤 Имя</span>
                    <span class="profile-value">@(Model.AppUser.DisplayName ?? "—")</span>
                </div>
                <div class="profile-row">
                    <span class="profile-label">🔗 Username</span>
                    <span class="profile-value">@(Model.AppUser.UserName ?? "—")</span>
                </div>
                <div class="profile-row">
                    <span class="profile-label">✈️ Telegram ID</span>
                    <span class="profile-value">@(Model.AppUser.TelegramId ?? "—")</span>
                </div>
                <div class="profile-row">
                    <span class="profile-label">📧 Email</span>
                    <span class="profile-value">@(Model.AppUser.Email ?? "—")</span>
                </div>
                <div class="profile-row">
                    <span class="profile-label">📅 Создан</span>
                    <span class="profile-value">@Model.AppUser.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </div>
            </div>
        }

        <a href="/" class="btn-primary" style="display:block;text-align:center;margin-top:20px;text-decoration:none">
            На главную
        </a>

    </div>
</div>
